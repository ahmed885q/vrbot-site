{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "vrbot.me" }],
      "destination": "https://www.vrbot.me/:path*",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/expiring-subs",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/run-tasks",
      "schedule": "0 0,6,12,18 * * *"
    },
    {
      "path": "/api/cron/check-trials",
      "schedule": "0 * * * *"
    }
  ]
}
